# Required
# Local example (docker-compose.yml uses port 15432)
DATABASE_URL="postgresql://app:app@localhost:15432/app?schema=public"

# Production example: self-hosted PostgreSQL on the same EC2 host or a private DB host
# DATABASE_URL="postgresql://USER:PASSWORD@127.0.0.1:5432/DB?schema=public"

# Optional managed PostgreSQL example:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public&sslmode=require"
# If SSL handshake fails due to missing CA verification, Prisma docs suggest `sslmode=no-verify`.

# Auth (JWT HMAC secret)
AUTH_SECRET="CHANGE_ME"

# Optional server config
PORT=3000
CORS_ORIGIN="*"

# SMS Webhook (MacroDroid → 서버 입금 문자 전달)
SMS_WEBHOOK_SECRET="CHANGE_ME"
SMS_WEBHOOK_PATH="/CHANGE_ME"

